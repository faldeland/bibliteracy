{
  "name": "bibliteracy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build:xrefs": "tsx scripts/buildCrossRefs.ts",
    "build:strongs": "tsx scripts/buildStrongsIndex.ts",
    "verify": "npm run lint && npm run typecheck && npm run test",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:new": "supabase migration new",
    "db:diff": "supabase db diff -f",
    "db:lint": "supabase db lint",
    "db:link": "supabase link",
    "db:push": "supabase db push --linked"
  },
  "dependencies": {
    "@livekit/components-react": "^2.9.18",
    "@livekit/components-styles": "^1.1.7",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.49.4",
    "@tanstack/react-query": "^5.66.0",
    "framer-motion": "^12.6.0",
    "livekit-client": "^2.15.7",
    "livekit-server-sdk": "^2.13.0",
    "next": "15.5.15",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.1.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.7",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.20.0",
    "eslint-config-next": "15.5.15",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.1",
    "supabase": "^2.92.1",
    "tailwindcss": "^4.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.4"
  }
}
