# If you set `basePath` in next.config.ts, set the same value here so the
# browser can reach `/api/*` routes (e.g. `/myapp/api/bible/chapter`).
# NEXT_PUBLIC_BASE_PATH=/myapp

# Public Supabase config (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase service role (NEVER expose to the browser).
# Used for writes that need to bypass RLS, including the LLM audit log
# (public.llm_audit_log, created by supabase/migrations/20260419000000_llm_audit_log.sql).
# When unset, the audit writer silently no-ops — the app still works.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LiveKit Cloud (https://cloud.livekit.io)
# Required for the lounge in the browser — must use NEXT_PUBLIC_ (not LIVEKIT_URL alone).
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
# Optional server-only alias; token route accepts this if NEXT_PUBLIC_LIVEKIT_URL is unset.
# LIVEKIT_URL=wss://your-project.livekit.cloud

# ─── Bible publisher APIs (server-side only) ────────────────────────────────
# These unlock licensed translations in the Bible reader. Each is OPTIONAL —
# leave it blank and the corresponding translation just shows as disabled in
# the picker. The values are NEVER exposed to the browser; only the
# /api/bible/chapter route reads them when fetching that translation.
#
# ESV — Crossway, free tier (~5,000 verses/day per key, non-commercial).
#   Get a key: https://api.esv.org/account/create-application/
ESV_API_KEY=
#
# NLT — Tyndale House, free with API key.
#   Get a key: https://api.nlt.to/
NLT_API_KEY=

# ─── PipeLLM (LLM gateway) ───────────────────────────────────────────────────
# Every LLM-backed feature in the app routes through PipeLLM's OpenAI-
# compatible gateway (https://docs.pipellm.ai). OPTIONAL — leave the key
# blank and those features simply hide themselves.
#   Get a key: https://console.pipellm.ai/
PIPELLM_API_KEY=
# Optional override for the gateway base URL. Defaults to the native route
# https://api.pipellm.ai/v1 . Set this only if your PipeLLM deployment uses
# a custom host or a different mount path.
PIPELLM_BASE_URL=
#
# ── Per-use-case model selection ──
# Each feature has its own model knob. Resolution order:
#   1. PIPELLM_MODEL_<USE_CASE>     (e.g. PIPELLM_MODEL_WORD_USAGE)
#   2. PIPELLM_MODEL_DEFAULT        (global fallback)
#   3. Hardcoded default in lib/llm/pipellm.ts
# Any OpenAI-compatible slug PipeLLM exposes is valid (gpt-4o-mini,
# gpt-4o, claude-sonnet-4-20250514, gemini-2.0-flash, etc.).
#
# Global default used when a feature-specific var isn't set.
PIPELLM_MODEL_DEFAULT=
# "In its time" section on the word-study popover. Short scholarly notes
# about how a Hebrew/Greek word was used in its own day.
PIPELLM_MODEL_WORD_USAGE=
# AI Assistant deep-dive drawer — full multi-section word study
# (morphology, semantic range, period usage, theological significance,
# translation history, related entries). Defaults to gpt-4o because the
# richer output benefits from a stronger model.
PIPELLM_MODEL_WORD_DEEP_DIVE=
# Post-generation citation-claim auditor. Runs a narrow adversarial
# consistency check of every drafted word study against the retrieved
# BDB / Thayer lexicon entry (see lib/llm/citationAudit.ts). A fast,
# cheap model is ideal — defaults to gpt-4o-mini.
PIPELLM_MODEL_CITATION_AUDIT=
